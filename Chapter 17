# Chapter 17 – Merging and joining DataFrames
import pandas as pd

customers = pd.DataFrame({
    "customer_id": [1, 2, 3, 4, 5],
    "name":        ["Alice","Bob","Carlos","Diana","Eve"],
    "city":        ["London","Paris","Madrid","Berlin","Rome"],
})
orders = pd.DataFrame({
    "order_id":    [101,102,103,104,105,106],
    "customer_id": [1, 2, 1, 3, 2, 6],
    "product":     ["Alpha","Beta","Gamma","Alpha","Alpha","Beta"],
    "amount":      [299.99,149.50,89.99,299.99,299.99,149.50],
})

inner = pd.merge(orders, customers, on="customer_id", how="inner")
print(f"Inner join: {len(inner)} rows")
print(inner[["order_id","name","product","amount"]])

left  = pd.merge(orders, customers, on="customer_id", how="left")
print(f"\nLeft join: {len(left)} rows")
print(left[["order_id","name","product","amount"]].to_string(index=False))

customer_totals = inner.groupby("name")["amount"].sum().reset_index()
customer_totals.columns = ["name","total_spent"]
final = pd.merge(customers, customer_totals, on="name", how="left").fillna(0)
print("\nCustomer spending:")
print(final.to_string(index=False))

