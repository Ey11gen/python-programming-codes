# Chapter 17 – Full analysis pipeline with Excel output
# Requires: pip install pandas openpyxl numpy
import pandas as pd
import numpy as np

def load_sales_data():
    np.random.seed(42)
    n = 200
    df = pd.DataFrame({
        "product": np.random.choice(["Alpha","Beta","Gamma","Delta"], n),
        "region":  np.random.choice(["North","South","East","West"],  n),
        "units":   np.random.randint(10, 300, n),
        "price":   np.random.choice([29.99, 49.99, 89.99, 119.99],   n),
    })
    mask = np.random.random(n) < 0.05
    df.loc[mask, "units"] = np.nan
    return df

def clean_data(df):
    df = df.copy()
    df["units"]   = df["units"].fillna(df.groupby("product")["units"].transform("median"))
    df["units"]   = df["units"].astype(int)
    df["revenue"] = df["units"] * df["price"]
    return df

def analyze(df):
    by_product = df.groupby("product").agg(
        total_units   =("units",   "sum"),
        total_revenue =("revenue", "sum"),
        transactions  =("units",   "count"),
    ).round(2).sort_values("total_revenue", ascending=False)
    by_region = df.groupby("region")["revenue"].sum().sort_values(ascending=False)
    top5      = df.nlargest(5, "revenue")[["product","region","units","revenue"]]
    return by_product, by_region, top5

raw            = load_sales_data()
clean          = clean_data(raw)
prod, reg, top = analyze(clean)

print("=== By Product ===")
print(prod)
print("\n=== By Region ===")
print(reg)
print("\n=== Top 5 Transactions ===")
print(top.to_string(index=False))

with pd.ExcelWriter("analysis_report.xlsx", engine="openpyxl") as writer:
    prod.to_excel(writer, sheet_name="By Product")
    reg.to_excel(writer, sheet_name="By Region")
    top.to_excel(writer, sheet_name="Top Transactions", index=False)
print("\nReport saved: analysis_report.xlsx")

