# Chapter 17 – Transforming, sorting, and pivot tables
import pandas as pd
import numpy as np

df = pd.DataFrame({
    "name":   ["Alice","Bob","Carlos","Diana","Eve"],
    "dept":   ["Eng","Mktg","Eng","HR","Eng"],
    "salary": [75000, 55000, 82000, 60000, 91000],
    "years":  [5, 3, 8, 4, 10],
    "rating": [4.2, 3.8, 4.7, 4.0, 4.9],
})

def grade_rating(r):
    if r >= 4.5:  return "Excellent"
    elif r >= 4.0: return "Good"
    elif r >= 3.5: return "Average"
    return "Below Average"

df["perf_grade"] = df["rating"].apply(grade_rating)
df["bonus"]      = df.apply(
    lambda row: row["salary"] * 0.15 if row["rating"] >= 4.5 else row["salary"] * 0.05,
    axis=1
)
df["salary_band"] = pd.cut(df["salary"], bins=[0,60000,75000,100000], labels=["Lower","Mid","Upper"])
print(df[["name","salary","rating","perf_grade","bonus","salary_band"]])

by_salary = df.sort_values("salary", ascending=False)
print("\nBy salary (desc):")
print(by_salary[["name","salary"]].to_string(index=False))

