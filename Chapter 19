# Chapter 19 – Closures and higher-order functions
def make_multiplier(factor):
    def multiplier(x):
        return x * factor
    return multiplier

double  = make_multiplier(2)
triple  = make_multiplier(3)
times10 = make_multiplier(10)
print(double(7))
print(triple(7))
print(times10(7))

pipeline = [double, triple, times10]
value    = 5
for transform in pipeline:
    value = transform(value)
    print(f"After {transform.__name__}: {value}")

def make_counter(start=0, step=1):
    count = [start]
    def counter():
        value    = count[0]
        count[0] += step
        return value
    return counter

c1 = make_counter(0, 1)
c2 = make_counter(100, 10)
print(c1(), c1(), c1())
print(c2(), c2(), c2())

# Chapter 19 – Decorators
import time
import functools

def timer(func):
    """Decorator that measures and prints execution time."""
    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        start  = time.perf_counter()
        result = func(*args, **kwargs)
        end    = time.perf_counter()
        print(f"{func.__name__} took {(end-start)*1000:.2f}ms")
        return result
    return wrapper

@timer
def compute_sum(n):
    """Sum all integers from 1 to n."""
    return sum(range(n + 1))

print(compute_sum(1_000_000))

# lru_cache decorator
@functools.lru_cache(maxsize=None)
def fib_cached(n):
    """Fibonacci using memoization via lru_cache."""
    if n <= 1:
        return n
    return fib_cached(n - 1) + fib_cached(n - 2)

print(fib_cached(50))
print(fib_cached.cache_info())

