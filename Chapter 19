# Chapter 19 – Generators and lazy evaluation
def count_up(start, stop, step=1):
    """A generator that yields numbers from start to stop."""
    current = start
    while current <= stop:
        yield current
        current += step

gen = count_up(1, 10, 2)
print(next(gen))
print(next(gen))
print(next(gen))

for n in count_up(0, 20, 5):
    print(n, end=" ")
print()

def fibonacci():
    """Yield Fibonacci numbers indefinitely."""
    a, b = 0, 1
    while True:
        yield a
        a, b = b, a + b

def take(n, iterable):
    """Take the first n items from any iterable."""
    count = 0
    for item in iterable:
        if count >= n:
            return
        yield item
        count += 1

fib_gen   = fibonacci()
first_15  = list(take(15, fib_gen))
print(first_15)

# Generator pipeline
def pipeline_squares_of_evens(limit):
    numbers = (n for n in range(limit))
    evens   = (n for n in numbers if n % 2 == 0)
    squares = (n ** 2 for n in evens)
    return squares

print(list(pipeline_squares_of_evens(10)))

