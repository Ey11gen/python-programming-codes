# Chapter 3 – f-strings and format method
name = "Alice"
age  = 30
msg  = f"Hello, {name}. You are {age} years old."
print(msg)

width  = 8
height = 5
print(f"Area: {width * height} sq meters.")

pi = 3.14159265
print(f"Pi to 2 dp: {pi:.2f}")

price = 1_234.567
print(f"Price: ${price:,.2f}")

# format() method
msg2 = "Hello, {}. You are {} years old.".format(name, age)
print(msg2)

# Chapter 3 – Multiline strings and escape characters
poem = """Roses are red,
Violets are blue,
Python is great,
