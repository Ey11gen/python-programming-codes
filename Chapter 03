# Chapter 3 – String indexing and slicing
language = "Python"
print(language[0])
print(language[2])
print(language[5])
print(language[-1])
print(language[-2])
print(len(language))

print(language[0:3])
print(language[2:5])
print(language[:3])
print(language[3:])
print(language[:])

alphabet = "abcdefghij"
print(alphabet[0:10:2])   # every other character

word = "Python"
print(word[::-1])          # reverse

# Chapter 3 – Essential string methods
text = "hello, World!"
print(text.upper())
print(text.lower())
print(text.title())
print(text.capitalize())

raw_input = "   Hello, World!   "
print(repr(raw_input.strip()))
print(repr(raw_input.lstrip()))
print(repr(raw_input.rstrip()))

sentence = "The quick brown fox"
print(sentence.find("quick"))
print(sentence.find("slow"))

message     = "I love cats. Cats are great. My cat is huge."
new_message = message.replace("cat", "dog")
print(new_message)

csv_line = "Alice,30,Engineer,London"
parts    = csv_line.split(",")
print(parts)

words    = ["The", "quick", "brown", "fox"]
sentence = " ".join(words)
print(sentence)

print("12345".isdigit())
print("hello".isalpha())
print("hello123".isalnum())
print("   ".isspace())

filename = "report_2026.pdf"
print(filename.endswith(".pdf"))
print(filename.startswith("report"))

# Chapter 3 – Concatenation, repetition, membership
first_name = "Alice"
last_name  = "Smith"
full_name  = first_name + " " + last_name
print(full_name)

separator = "-" * 30
print(separator)

echo = "Ha" * 5
print(echo)

sentence = "The quick brown fox"
print("quick" in sentence)
print("slow"  in sentence)
print("slow" not in sentence)
