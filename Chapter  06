def min_max(numbers):
    smallest = numbers[0]
    largest  = numbers[0]
    for n in numbers:
        if n < smallest:
            smallest = n
        if n > largest:
            largest  = n
    return smallest, largest

low, high = min_max([4, 17, 2, 9, 31, 6])
print(f"Minimum: {low}")
print(f"Maximum: {high}")

