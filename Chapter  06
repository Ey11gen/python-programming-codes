# Chapter 6 – A practical function library: text analysis
def word_count(text):
    """Return the number of words in a string."""
    return len(text.split())

def char_count(text, include_spaces=True):
    """Return the number of characters, optionally excluding spaces."""
    if include_spaces:
        return len(text)
    return len(text.replace(" ", ""))

def most_common_word(text):
    """Return the most frequently appearing word (case-insensitive)."""
    words      = text.lower().split()
    best_word  = ""
    best_count = 0
    for word in set(words):
        current = words.count(word)
        if current > best_count:
            best_count = current
            best_word  = word
    return best_word, best_count

sample = "the cat sat on the mat the cat was happy"
print(f"Words:         {word_count(sample)}")
print(f"Chars (spaces):{char_count(sample)}")
print(f"Chars (no spc):{char_count(sample, include_spaces=False)}")
word, freq = most_common_word(sample)
print(f"Most common:   '{word}' ({freq} times)")

# Chapter 6 – Mini-project: Unit Conversion Tool
def celsius_to_fahrenheit(celsius):
    """Convert Celsius to Fahrenheit."""
    return (celsius * 9 / 5) + 32

def fahrenheit_to_celsius(fahrenheit):
    """Convert Fahrenheit to Celsius."""
    return (fahrenheit - 32) * 5 / 9

def km_to_miles(km):
    """Convert kilometers to miles."""
    return km * 0.621371

def miles_to_km(miles):
    """Convert miles to kilometers."""
    return miles / 0.621371

def kg_to_pounds(kg):
    """Convert kilograms to pounds."""
    return kg * 2.20462

def convert(value, conversion_type):
    """Dispatch a conversion based on conversion_type string."""
    if conversion_type == "c_to_f":
        return celsius_to_fahrenheit(value)
    elif conversion_type == "f_to_c":
        return fahrenheit_to_celsius(value)
    elif conversion_type == "km_to_mi":
        return km_to_miles(value)
    elif conversion_type == "mi_to_km":
        return miles_to_km(value)
    elif conversion_type == "kg_to_lb":
        return kg_to_pounds(value)
    else:
        print(f"Unknown conversion type: {conversion_type}")
        return None

if __name__ == "__main__":
    print(f"100 C  = {convert(100, 'c_to_f'):.1f} F")
    print(f"72 F   = {convert(72,  'f_to_c'):.1f} C")
    print(f"10 km  = {convert(10,  'km_to_mi'):.3f} miles")
    print(f"5 mi   = {convert(5,   'mi_to_km'):.3f} km")
    print(f"70 kg  = {convert(70,  'kg_to_lb'):.2f} lbs")
