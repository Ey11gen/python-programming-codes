# Chapter 6 – *args and **kwargs
def total(*args):
    running_sum = 0
    for value in args:
        running_sum += value
    return running_sum

print(total(5, 10))
print(total(1, 2, 3, 4, 5))
print(total(100, 200, 300, 400))

def describe_items(category, *items):
    print(f"Category: {category}")
    for item in items:
        print(f"  - {item}")

describe_items("Fruit", "apple", "banana", "mango")

def display_profile(**kwargs):
    print("User Profile:")
    for key, value in kwargs.items():
        print(f"  {key}: {value}")

display_profile(name="Alice", age=30, city="London", role="Engineer")

# Chapter 6 – Docstrings and function documentation
def calculate_circle_area(radius):
    """
    Calculate and return the area of a circle.

    Parameters:
        radius (float): The radius of the circle. Must be positive.

    Returns:
        float: The area, computed as pi * radius squared.
    """
    pi = 3.14159265
    return pi * radius ** 2

area = calculate_circle_area(5)
print(f"Area: {area:.2f}")
print(calculate_circle_area.__doc__)

