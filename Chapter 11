# Chapter 11 – A reusable module (import from main_example.py)

def word_count(text):
    """Return the number of words in the given text."""
    return len(text.split())

def char_frequency(text):
    """Return a dict mapping each char to its frequency."""
    freq = {}
    for ch in text.lower():
        if ch.isalpha():
            freq[ch] = freq.get(ch, 0) + 1
    return freq

def is_pangram(text):
    """Return True if text contains every letter of the alphabet."""
    letters = set(ch for ch in text.lower() if ch.isalpha())
    return len(letters) == 26

COMMON_WORDS = {"the","a","an","is","it","in","of","to"}

if __name__ == "__main__":
    sentence = "The quick brown fox jumps over the lazy dog"
    print(f"Word count:  {word_count(sentence)}")
    print(f"Is pangram:  {is_pangram(sentence)}")
    freq = char_frequency(sentence)
    top  = sorted(freq.items(), key=lambda x: x[1], reverse=True)[:5]
    print(f"Top 5 chars: {top}")
