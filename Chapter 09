# Process: read raw, filter, write clean
with open("raw_numbers.txt", "w") as f:
    f.write("10\n25\nBAD\n7\n\n99\nERROR\n42\n")

valid_numbers = []
skipped       = 0
with open("raw_numbers.txt", "r") as f:
    for line in f:
        stripped = line.strip()
        if stripped.isdigit():
            valid_numbers.append(int(stripped))
        else:
            skipped += 1

with open("cleaned_numbers.txt", "w") as f:
    for number in valid_numbers:
        f.write(str(number) + "\n")

print(f"Valid: {len(valid_numbers)}, Skipped: {skipped}")
print(f"Sum of valid numbers: {sum(valid_numbers)}")
