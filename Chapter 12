# Chapter 12 – Defining classes
class Dog:
    def __init__(self, name, breed, age):
        self.name   = name
        self.breed  = breed
        self.age    = age
        self.tricks = []

    def bark(self):
        print(f"{self.name} says: Woof!")

    def learn_trick(self, trick):
        self.tricks.append(trick)
        print(f"{self.name} learned '{trick}'!")

    def show_tricks(self):
        if self.tricks:
            print(f"{self.name}'s tricks: {', '.join(self.tricks)}")
        else:
            print(f"{self.name} does not know any tricks yet.")

    def have_birthday(self):
        self.age += 1
        print(f"Happy birthday, {self.name}! Now {self.age} years old.")

dog = Dog("Rex", "Labrador", 3)
dog.bark()
dog.learn_trick("sit")
dog.learn_trick("shake")
dog.show_tricks()
dog.have_birthday()
print(dog.age)

# Chapter 12 – Properties with @property and setter
class Temperature:
    def __init__(self, celsius=0):
        self._celsius = celsius

    @property
    def celsius(self):
        return self._celsius

    @celsius.setter
    def celsius(self, value):
        if value < -273.15:
            raise ValueError(f"Temperature below absolute zero: {value}")
        self._celsius = value

    @property
    def fahrenheit(self):
        return self._celsius * 9 / 5 + 32

t = Temperature(25)
print(t.celsius)
print(t.fahrenheit)
t.celsius = 100
print(t.fahrenheit)
try:
    t.celsius = -300
except ValueError as e:
    print(e)

# Chapter 12 – Working with multiple objects
class Student:
    def __init__(self, name, grades):
        self.name   = name
        self.grades = grades

    @property
    def average(self):
        if not self.grades:
            return 0.0
        return sum(self.grades) / len(self.grades)

    @property
    def letter_grade(self):
        avg = self.average
        if avg >= 90: return "A"
        elif avg >= 80: return "B"
        elif avg >= 70: return "C"
        elif avg >= 60: return "D"
        return "F"

    def __str__(self):
        return f"{self.name:<15} Avg: {self.average:5.1f}  Grade: {self.letter_grade}"

class_roster = [
    Student("Alice",   [92, 88, 95, 91]),
    Student("Bob",     [75, 68, 72, 80]),
    Student("Carlos",  [85, 90, 88, 92]),
    Student("Diana",   [60, 55, 63, 58]),
    Student("Eve",     [98, 95, 97, 99]),
]

print("--- Class Report ---")
for student in class_roster:
    print(student)

top = max(class_roster, key=lambda s: s.average)
print(f"\nTop student: {top.name} with avg {top.average:.1f}")
passing   = [s for s in class_roster if s.average >= 70]
print(f"Passing: {len(passing)} of {len(class_roster)}")
class_avg = sum(s.average for s in class_roster) / len(class_roster)
print(f"Class average: {class_avg:.1f}")

# Chapter 12 – Task manager class (mini-project)
import datetime

class Task:
    _id_counter = 0

    def __init__(self, title, priority="medium", due_date=None):
        Task._id_counter += 1
        self.task_id    = Task._id_counter
        self.title      = title
        self.priority   = priority
        self.due_date   = due_date
        self.completed  = False
        self.created_at = datetime.date.today()
        self.notes      = []

    def complete(self):
        self.completed = True
        print(f"Task {self.task_id} '{self.title}' marked complete.")

    def add_note(self, note):
        self.notes.append(note)

    def is_overdue(self):
        if self.due_date is None or self.completed:
            return False
        return datetime.date.today() > self.due_date

    def __str__(self):
        status  = "Done" if self.completed else "Pending"
        overdue = " [OVERDUE]" if self.is_overdue() else ""
        due_str = str(self.due_date) if self.due_date else "No deadline"
        return f"[{self.task_id}] {self.title} | {self.priority.upper()} | {status}{overdue} | Due: {due_str}"

if __name__ == "__main__":
    t1 = Task("Write chapter 12", "high",   datetime.date(2026, 3, 20))
