# Chapter 12 – BankAccount class with __str__ and __repr__
class BankAccount:
    def __init__(self, owner, account_id, balance=0.0):
        self.owner      = owner
        self.account_id = account_id
        self.balance    = balance

    def deposit(self, amount):
        if amount <= 0:
            raise ValueError("Deposit amount must be positive.")
        self.balance += amount
        return self.balance

    def withdraw(self, amount):
        if amount <= 0:
            raise ValueError("Withdrawal amount must be positive.")
        if amount > self.balance:
            raise ValueError(f"Insufficient funds. Balance: {self.balance:.2f}")
        self.balance -= amount
        return self.balance

    def __str__(self):
        return f"Account[{self.account_id}] Owner: {self.owner}, Balance: ${self.balance:.2f}"

    def __repr__(self):
        return f"BankAccount(owner='{self.owner}', account_id='{self.account_id}', balance={self.balance})"

acct = BankAccount("Alice", "ACC-001", 1000.00)
print(acct)
acct.deposit(250)
acct.withdraw(75)
print(f"Final balance: ${acct.balance:.2f}")

